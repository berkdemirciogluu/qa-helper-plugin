{
  "name": "qa-helper-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "QA Helper Chrome Extension — session recording, bug reporting, ZIP export and Jira integration",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:zip": "vite build && node scripts/zip.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@preact/signals": "^2.8.1",
    "jszip": "^3.10.1",
    "lucide-preact": "^0.555.0",
    "preact": "^10.27.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.0.300",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "eslint-config-preact": "^2.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
